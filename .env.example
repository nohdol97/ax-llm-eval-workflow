# ============================================================================
# ax-llm-eval-workflow 환경 변수
# 이 파일을 .env로 복사한 뒤 실제 값을 입력하세요.
# cp .env.example .env
# ============================================================================

# ── 일반 설정 ──────────────────────────────────────────────────────
# 실행 환경 (development | staging | production)
APP_ENV=development

# ── Frontend (Next.js) ─────────────────────────────────────────────
# [필수] Backend API 주소
NEXT_PUBLIC_API_URL=http://localhost:8000
# [필수] Langfuse Web UI 주소 (프론트엔드에서 링크용)
NEXT_PUBLIC_LANGFUSE_URL=http://localhost:3001

# ── Backend (FastAPI) ──────────────────────────────────────────────
# [필수] FastAPI 서버 포트
BACKEND_PORT=8000
# [필수] CORS 허용 오리진 (쉼표 구분, 와일드카드 * 금지)
CORS_ALLOWED_ORIGINS=http://localhost:3000
# [필수] LiteLLM Proxy 내부 URL
LITELLM_BASE_URL=http://litellm:4000
# [필수] Langfuse 서버 내부 URL
LANGFUSE_HOST=http://langfuse:3000

# ── 인증 (JWT 검증) ───────────────────────────────────────────────
# [필수] JWKS 엔드포인트 (사내 Auth 서비스에서 공개키 조회)
AUTH_JWKS_URL=https://auth.example.com/.well-known/jwks.json
# [선택] JWT issuer 검증
AUTH_JWT_ISSUER=https://auth.example.com
# [선택] JWT audience 검증
AUTH_JWT_AUDIENCE=ax-llm-eval-workflow

# ── Langfuse v3 ────────────────────────────────────────────────────
# [필수] Langfuse 프로젝트 API 키 (Labs Backend에서 Langfuse SDK 호출 시 사용)
LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key
LANGFUSE_SECRET_KEY=sk-lf-your-secret-key
# [필수] Langfuse NextAuth 시크릿 (32자 이상 랜덤 문자열)
LANGFUSE_NEXTAUTH_SECRET=your-nextauth-secret-at-least-32-chars
# [필수] Langfuse Salt (32자 이상 랜덤 문자열)
LANGFUSE_SALT=your-salt-at-least-32-chars
# [선택] Langfuse 초기 조직/프로젝트 설정 (자동 프로비저닝)
LANGFUSE_INIT_ORG_ID=
LANGFUSE_INIT_PROJECT_ID=

# ── PostgreSQL ─────────────────────────────────────────────────────
# [필수] Langfuse 메타데이터 저장소
POSTGRES_USER=langfuse
POSTGRES_PASSWORD=your-postgres-password
POSTGRES_DB=langfuse

# ── ClickHouse ─────────────────────────────────────────────────────
# [필수] Langfuse 시계열 분석 데이터
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=your-clickhouse-password
CLICKHOUSE_DB=langfuse
# [필수] Labs 읽기 전용 계정 (분석/대시보드용 직접 쿼리)
CLICKHOUSE_READONLY_USER=labs_readonly
CLICKHOUSE_READONLY_PASSWORD=your-readonly-password

# ── Redis ──────────────────────────────────────────────────────────
# [필수] Langfuse 이벤트 큐 + Labs 실험 상태 저장
REDIS_PASSWORD=your-redis-password
# [선택] Labs 전용 Redis DB 번호 (Langfuse와 분리 시)
LABS_REDIS_DB=1
# [선택] 실험 상태 TTL (초, 기본 86400 = 24시간)
LABS_EXPERIMENT_STATE_TTL=86400

# ── LiteLLM Proxy ─────────────────────────────────────────────────
# [필수] LiteLLM Master Key (최소 32자, Secret Manager에서 관리, 90일 로테이션)
LITELLM_MASTER_KEY=sk-litellm-your-master-key-at-least-32-chars

# ── LLM Provider API 키 ───────────────────────────────────────────
# LiteLLM Proxy에서만 관리, Backend 코드에서 직접 접근 금지

# [필수] Azure OpenAI
AZURE_API_KEY=your-azure-openai-api-key
AZURE_API_BASE=https://your-resource.openai.azure.com
AZURE_API_VERSION=2024-12-01-preview

# [필수] Google Gemini
GEMINI_API_KEY=your-gemini-api-key

# [필수] Anthropic (Claude)
ANTHROPIC_API_KEY=your-anthropic-api-key

# [필수] OpenAI Direct
OPENAI_API_KEY=your-openai-api-key

# [선택] AWS Bedrock (IAM 인증 사용 시 키 불필요)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION_NAME=us-east-1

# ── Evaluator 샌드박스 ────────────────────────────────────────────
# [선택] Custom Evaluator Docker 이미지 이름
EVAL_SANDBOX_IMAGE=ax-eval-sandbox:latest
# [선택] 컨테이너 실행 제한
EVAL_SANDBOX_TIMEOUT_SEC=5
EVAL_SANDBOX_MEMORY_LIMIT=128m
# [선택] Docker 네트워크 설정 (none = 네트워크 차단)
EVAL_SANDBOX_NETWORK=none

# ── 로깅 ──────────────────────────────────────────────────────────
# [선택] 로그 레벨 (DEBUG | INFO | WARNING | ERROR)
LOG_LEVEL=INFO
# [선택] 구조화된 JSON 로그 출력 (true | false)
LOG_JSON_FORMAT=true
