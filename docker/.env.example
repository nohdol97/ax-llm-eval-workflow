# ============================================================================
# ax-llm-eval-workflow — 환경변수 템플릿
#
# 사용법:
#   cp docker/.env.example docker/.env
#   # 사내 인프라팀으로부터 받은 실제 값을 채워 넣는다.
#   # docker/.env 는 .gitignore 대상이며, 절대 커밋하지 않는다.
#
# 주의:
#   - LLM Provider 키(AZURE_API_KEY / GEMINI_API_KEY 등)는 본 파일에
#     절대 포함하지 않는다. 사내 LiteLLM Proxy가 단독 보관하며, 본
#     프로젝트는 LITELLM_VIRTUAL_KEY 로만 호출한다 (ADR-011 참조).
#   - 운영 환경에서는 본 파일 대신 사내 secret store(Vault/KMS) 경유로
#     Docker secrets 형태로 주입한다 (docker-compose.prod.yml 참조).
#
# 참조: docs/BUILD_ORDER.md 작업 1-3 / docs/adr/ADR-011-secrets-management.md
# ============================================================================

# ── 일반 ──────────────────────────────────────────────────────────
# 실행 환경 식별자 (development | demo | production)
LABS_ENV=development
# 컨테이너 이미지 태그 (빌드 후 docker tag 시 일치시킬 것)
LABS_IMAGE_TAG=latest

# === 사내 공용 인프라 엔드포인트 =====================================

# ── Langfuse (사내 공용) ──────────────────────────────────────────
# 사내 Langfuse가 발급한 프로젝트별 키. 본 프로젝트 전용 키 사용.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# 사내 Langfuse 호스트
LANGFUSE_HOST=https://langfuse.internal.example.com

# ── LiteLLM (사내 공용) ────────────────────────────────────────────
# 본 프로젝트 전용 Virtual Key (사용량/예산/rate limit 분리). 사내
# LiteLLM 운영팀이 발급한다. LLM Provider API 키는 사내 LiteLLM이
# 단독 보관하며 본 프로젝트에서는 절대 보관/노출하지 않는다.
LITELLM_VIRTUAL_KEY=
LITELLM_BASE_URL=https://litellm.internal.example.com

# ── ClickHouse (Langfuse 내부, 사내가 readonly 계정 발급) ────────
# Phase 6 분석 쿼리에서 사용. 사내 보안정책상 직접 접근 불가 시
# USE_LANGFUSE_PUBLIC_API_FALLBACK=true 로 폴백 (ADR-012 참조).
CLICKHOUSE_HOST=clickhouse.internal.example.com
CLICKHOUSE_PORT=8443
CLICKHOUSE_SECURE=true
CLICKHOUSE_DB=langfuse
CLICKHOUSE_READONLY_USER=labs_readonly
CLICKHOUSE_READONLY_PASSWORD=
# 폴백: 사내 보안정책상 ClickHouse 직접 접근 불가 시 true 로 설정
USE_LANGFUSE_PUBLIC_API_FALLBACK=false

# ── Prometheus (사내 공용 — 본 프로젝트는 /metrics 노출만 담당) ──
# Backend가 노출하는 메트릭 path. 사내 Prometheus가 scrape한다.
LABS_METRICS_ENABLED=true
LABS_METRICS_PATH=/metrics
# 헬스체크 시 사내 Prometheus 도달성 확인용 (선택)
PROMETHEUS_QUERY_URL=https://prometheus.internal.example.com

# ── OpenTelemetry (사내 공용 Collector) ────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=https://otel-collector.internal.example.com:4318
# 사내 OTel Collector 인증 토큰 (시크릿). URL-encoded 형식 주의.
OTEL_EXPORTER_OTLP_HEADERS=Authorization=Bearer%20<token>
OTEL_SERVICE_NAME=ax-llm-eval-workflow-backend
OTEL_RESOURCE_ATTRIBUTES=service.namespace=labs,deployment.environment=production
OTEL_TRACES_SAMPLER=parentbased_traceidratio
# 운영 0.1 / 데모 1.0 / 개발 0.0 (override에서 덮어쓰기)
OTEL_TRACES_SAMPLER_ARG=0.1

# ── Loki (사내 공용 — stdout JSON 로그를 사내 수집기가 picking) ──
LABS_LOG_FORMAT=json
LABS_LOG_LEVEL=INFO
LABS_LOG_LOKI_LABELS=service=ax-llm-eval-workflow-backend,env=production

# === 본 프로젝트 자체 운영 ===========================================

# ── Redis ─────────────────────────────────────────────────────────
# 1순위: 사내 공용 Redis 임차 (REDIS_URL을 사내 호스트로 설정).
# 차선: 자체 컨테이너 (compose profile=self-hosted-redis 활성화).
REDIS_URL=redis://:${REDIS_PASSWORD}@redis.internal.example.com:6379/${LABS_REDIS_DB:-1}
REDIS_PASSWORD=
# 사내 임차 시 합의된 DB 번호. 자체 컨테이너 사용 시 0.
LABS_REDIS_DB=1

# ── JWT (사내 Auth 서비스) ─────────────────────────────────────────
# 본 프로젝트는 JWT 검증만 수행 (서명 키는 사내 Auth 책임).
AUTH_JWKS_URL=https://auth.internal.example.com/.well-known/jwks.json
AUTH_JWT_AUDIENCE=labs
AUTH_JWT_ISSUER=https://auth.internal.example.com

# ── Frontend ─────────────────────────────────────────────────────
# Next.js가 빌드 시 inline하는 public 변수. Backend API 외부 경로.
NEXT_PUBLIC_API_BASE_URL=https://labs.internal.example.com/api/v1
NEXT_PUBLIC_LANGFUSE_URL=https://langfuse.internal.example.com
NEXT_PUBLIC_AUTH_LOGIN_URL=https://auth.internal.example.com/login
NEXT_PUBLIC_AUTH_CALLBACK_URL=https://labs.internal.example.com/auth/callback

# === 보안 경계 (절대 추가하지 않을 변수) =============================
# LLM Provider Keys 는 사내 LiteLLM이 단독 보관한다.
# 본 프로젝트 .env 에 절대 포함하지 않는다.
#   AZURE_API_KEY        ← 금지
#   GEMINI_API_KEY       ← 금지
#   ANTHROPIC_API_KEY    ← 금지
#   OPENAI_API_KEY       ← 금지
#   AWS_BEDROCK_*        ← 금지
# CI 단계에서 본 키 패턴이 검출되면 빌드를 실패시킨다 (ADR-011).
